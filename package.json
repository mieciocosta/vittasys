{
  "name": "vittasys-api",
  "version": "1.0.0",
  "description": "VittaSys — API de Gestão de Vacinação (Vittalis Saúde)",
  "main": "src/server.js",
  "scripts": {
    "start": "npx prisma db push && node src/server.js",
    "start:prod": "node src/server.js",

    "dev": "node --watch src/server.js",

    "db:generate": "npx prisma generate",
    "db:push": "npx prisma db push",
    "db:migrate": "npx prisma migrate deploy",
    "db:migrate:dev": "npx prisma migrate dev",
    "db:reset": "npx prisma migrate reset --force",

    "db:seed": "node prisma/seed.js",
    "db:setup": "npx prisma generate && npx prisma db push && node prisma/seed.js",

    "db:studio": "npx prisma studio",

    "setup": "npm install && npm run db:setup",

    "postinstall": "npx prisma generate"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@prisma/client": "^6.2.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "helmet": "^8.0.0",
    "morgan": "^1.10.0"
  },
  "devDependencies": {
    "prisma": "^6.2.0"
  }
}