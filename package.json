{
  "name": "vittasys",
  "version": "2.0.0",
  "description": "VittaSys — Sistema de Gestão de Vacinação (Vittalis Saúde)",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "node --watch src/server.js",
    "db:push": "npx prisma db push",
    "db:seed": "node prisma/seed.js",
    "db:studio": "npx prisma studio",
    "db:reset": "npx prisma db push --force-reset && node prisma/seed.js",
    "setup": "npm install && npx prisma generate && npx prisma db push && node prisma/seed.js",
    "postinstall": "npx prisma generate",
    "build": "npx prisma generate"
  },
  "engines": { "node": ">=18.0.0" },
  "dependencies": {
    "@prisma/client": "^6.2.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "helmet": "^8.0.0",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "xml2js": "^0.6.2"
  },
  "devDependencies": { "prisma": "^6.2.0" }
}
