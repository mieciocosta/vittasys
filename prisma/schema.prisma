generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Usuario {
  id        Int      @id @default(autoincrement())
  nome      String
  cargo     String
  email     String?  @unique
  pin       String
  perfil    String   @default("operador") // master, ativos, espontaneos, operador
  ativo     Boolean  @default(true)
  criadoEm  DateTime @default(now()) @map("criado_em")
  @@map("usuarios")
}

model Vacina {
  id                  Int      @id @default(autoincrement())
  codigo              String   @unique
  nome                String
  nomeTecnico         String?  @map("nome_tecnico")
  fabricante          String
  laboratorio         String?
  categoria           String?
  apresentacao        String?
  unidade             String   @default("dose")
  dosesEsquema        Int      @default(1) @map("doses_esquema")
  intervaloDias       Int      @default(0) @map("intervalo_dias")
  faixaEtariaInicio   String?  @map("faixa_etaria_inicio")
  faixaEtariaFim      String?  @map("faixa_etaria_fim")
  viaAdministracao    String?  @map("via_administracao")
  valorCustoMedio     Float    @default(0) @map("valor_custo_medio")
  valorVendaSugerido  Float    @default(0) @map("valor_venda_sugerido")
  observacoes         String?
  ativo               Boolean  @default(true)
  criadoEm            DateTime @default(now()) @map("criado_em")
  lotes               Lote[]
  planoVacinas        PlanoVacina[]
  planoDoses          PlanoContratadoDose[]
  movimentacoes       Movimentacao[]
  @@map("vacinas")
}

model Lote {
  id                    Int      @id @default(autoincrement())
  vacinaId              Int      @map("vacina_id")
  numeroLote            String   @unique @map("numero_lote")
  fabricante            String
  quantidadeTotal       Int      @map("quantidade_total")
  quantidadeDisponivel  Int      @map("quantidade_disponivel")
  quantidadeReservada   Int      @default(0) @map("quantidade_reservada")
  quantidadeAplicada    Int      @default(0) @map("quantidade_aplicada")
  validade              DateTime
  temperaturaArmazenamento String? @default("2-8°C") @map("temperatura_armazenamento")
  localArmazenamento    String?  @default("Câmara Fria Principal") @map("local_armazenamento")
  dataEntrada           DateTime @default(now()) @map("data_entrada")
  notaFiscalId          Int?     @map("nota_fiscal_id")
  valorUnitarioCusto    Float    @default(0) @map("valor_unitario_custo")
  status                String   @default("disponivel")
  observacoes           String?
  criadoEm              DateTime @default(now()) @map("criado_em")
  vacina                Vacina   @relation(fields: [vacinaId], references: [id])
  unidades              Unidade[]
  movimentacoes         Movimentacao[]
  @@index([vacinaId])
  @@index([validade])
  @@map("lotes")
}

model Unidade {
  id                    Int      @id @default(autoincrement())
  loteId                Int      @map("lote_id")
  codigoBarras          String   @map("codigo_barras")
  status                String   @default("disponivel") // disponivel, aplicada, descartada
  criadoEm              DateTime @default(now()) @map("criado_em")
  lote                  Lote     @relation(fields: [loteId], references: [id])
  movimentacoes         Movimentacao[]
  @@index([loteId])
  @@index([codigoBarras])
  @@map("unidades")
}

model Cliente {
  id                    Int      @id @default(autoincrement())
  codigoCliente         String?  @unique @map("codigo_cliente")
  nome                  String
  dataNascimento        DateTime? @map("data_nascimento")
  sexo                  String?
  cpf                   String?
  telefone              String?
  email                 String?
  tipoPaciente          String   @default("adulto") @map("tipo_paciente")
  tipoCliente           String   @default("espontaneo") @map("tipo_cliente")
  responsavelNome       String?  @map("responsavel_nome")
  responsavelParentesco String?  @map("responsavel_parentesco")
  responsavelCpf        String?  @map("responsavel_cpf")
  responsavelTelefone   String?  @map("responsavel_telefone")
  vendedorId            Int?     @map("vendedor_id")
  vacinadorId           Int?     @map("vacinador_id")
  status                String   @default("ativo")
  observacoes           String?
  observacoesClinicas   String?  @map("observacoes_clinicas")
  criadoEm              DateTime @default(now()) @map("criado_em")
  atualizadoEm          DateTime @updatedAt @map("atualizado_em")
  planosContratados     PlanoContratado[]
  movimentacoes         Movimentacao[]
  pagamentos            Pagamento[] @relation("ClientePagamentos")
  @@map("clientes")
}

model Plano {
  id                Int      @id @default(autoincrement())
  nome              String
  descricao         String?
  idadeInicio       Int      @default(0) @map("idade_inicio")
  idadeFim          Int      @default(18) @map("idade_fim")
  tipoPlano         String   @default("padrao") @map("tipo_plano")
  validadeMeses     Int      @default(18) @map("validade_meses")
  valorTabela       Float    @default(0) @map("valor_tabela")
  valorAvista       Float?   @map("valor_avista")
  valorCartao       Float?   @map("valor_cartao")
  parcelas          Int?     @default(1)
  descPagamento     String?  @map("desc_pagamento") // ex: "10x sem juros"
  status            String   @default("ativo")
  criadoEm          DateTime @default(now()) @map("criado_em")
  vacinas           PlanoVacina[]
  contratados       PlanoContratado[]
  @@map("planos")
}

model PlanoVacina {
  id                 Int    @id @default(autoincrement())
  planoId            Int    @map("plano_id")
  vacinaId           Int    @map("vacina_id")
  doses              Int    @default(1)
  mesPrevInicio      Int?   @map("mes_previsto_inicio")
  mesPrevFim         Int?   @map("mes_previsto_fim")
  plano              Plano  @relation(fields: [planoId], references: [id], onDelete: Cascade)
  vacina             Vacina @relation(fields: [vacinaId], references: [id])
  @@map("plano_vacinas")
}

model PlanoContratado {
  id                    Int      @id @default(autoincrement())
  clienteId             Int      @map("cliente_id")
  planoId               Int?     @map("plano_id")
  nomePlano             String   @map("nome_plano")
  idadeInicio           Int      @default(0) @map("idade_inicio")
  idadeFim              Int      @default(18) @map("idade_fim")
  tipoPlano             String   @default("padrao") @map("tipo_plano")
  dataInicioPlano       DateTime? @map("data_inicio_plano")
  dataFimPlano          DateTime? @map("data_fim_plano")
  valorCusto            Float    @default(0) @map("valor_custo")
  valorBruto            Float    @default(0) @map("valor_bruto")
  valorDesconto         Float    @default(0) @map("valor_desconto")
  percentualDesconto    Float    @default(0) @map("percentual_desconto")
  valorFinal            Float    @default(0) @map("valor_final")
  lucroPrevisto         Float    @default(0) @map("lucro_previsto")
  margemLucro           Float    @default(0) @map("margem_lucro_percentual")
  contratoAssinado      Boolean  @default(false) @map("contrato_assinado")
  statusContrato        String   @default("ativo") @map("status_contrato")
  formaPagamento        String?  @default("avista") @map("forma_pagamento") // avista, cartao
  vendedorId            Int?     @map("vendedor_id")
  vacinadorId           Int?     @map("vacinador_id")
  dataVenda             DateTime? @map("data_venda")
  observacoes           String?
  criadoEm              DateTime @default(now()) @map("criado_em")
  atualizadoEm          DateTime @updatedAt @map("atualizado_em")
  cliente               Cliente  @relation(fields: [clienteId], references: [id])
  plano                 Plano?   @relation(fields: [planoId], references: [id])
  doses                 PlanoContratadoDose[]
  pagamentos            Pagamento[]
  @@index([clienteId])
  @@map("planos_contratados")
}

model PlanoContratadoDose {
  id                 Int      @id @default(autoincrement())
  planoContratadoId  Int      @map("plano_contratado_id")
  vacinaId           Int      @map("vacina_id")
  doseNumero         Int      @default(1) @map("dose_numero")
  mesPrevisto        Int?     @map("mes_previsto")
  competencia        String?
  status             String   @default("pendente") // pendente, aplicada, cancelada, pendente_aprovacao
  dataAplicacao      DateTime? @map("data_aplicacao")
  localAplicacao     String?  @map("local_aplicacao")
  movimentacaoId     Int?     @map("movimentacao_id")
  tipoExcecao        String?  @map("tipo_excecao") // antecipacao, atraso, fora_janela, ajuste_manual
  planoContratado    PlanoContratado @relation(fields: [planoContratadoId], references: [id], onDelete: Cascade)
  vacina             Vacina   @relation(fields: [vacinaId], references: [id])
  @@index([planoContratadoId])
  @@index([vacinaId])
  @@map("plano_contratado_doses")
}

model AuditLog {
  id          Int      @id @default(autoincrement())
  acao        String   // login, logout, login_falha, criar, editar, excluir, aprovar, reprovar, retirada, estorno, etc
  entidade    String?  // movimentacao, cliente, plano, lote, unidade, etc
  entidadeId  Int?     @map("entidade_id")
  usuarioId   Int?     @map("usuario_id")
  usuarioNome String?  @map("usuario_nome")
  perfil      String?
  detalhes    String?  // JSON with before/after, motivo, etc
  ip          String?
  userAgent   String?  @map("user_agent")
  rota        String?
  sessaoId    String?  @map("sessao_id")
  fotoPath    String?  @map("foto_path") // path to webcam photo evidence
  criadoEm    DateTime @default(now()) @map("criado_em")
  @@index([usuarioId])
  @@index([acao])
  @@index([entidade, entidadeId])
  @@index([criadoEm])
  @@map("audit_logs")
}

model Pagamento {
  id                 Int      @id @default(autoincrement())
  planoContratadoId  Int      @map("plano_contratado_id")
  valorPago          Float    @map("valor_pago")
  dataPagamento      DateTime @map("data_pagamento")
  formaPagamento     String   @default("pix") @map("forma_pagamento")
  numeroParcela      Int      @default(1) @map("numero_parcela")
  observacao         String?
  criadoPor          Int?     @map("criado_por")
  clienteId          Int?     @map("cliente_id")
  criadoEm           DateTime @default(now()) @map("criado_em")
  planoContratado    PlanoContratado @relation(fields: [planoContratadoId], references: [id])
  cliente            Cliente? @relation("ClientePagamentos", fields: [clienteId], references: [id])
  @@index([planoContratadoId])
  @@map("pagamentos")
}

model Movimentacao {
  id                  Int      @id @default(autoincrement())
  tipo                String   // entrada, retirada, aplicacao, descarte, ajuste, estorno
  unidadeId           Int?     @map("unidade_id")
  loteId              Int?     @map("lote_id")
  vacinaId            Int?     @map("vacina_id")
  clienteId           Int?     @map("cliente_id")
  usuarioId           Int      @map("usuario_id")
  aplicadoPor         Int?     @map("aplicado_por")
  tipoCliente         String?  @map("tipo_cliente")
  tipoAtendimento     String?  @default("normal") @map("tipo_atendimento")
  localAplicacao      String?  @map("local_aplicacao")
  quantidade          Int      @default(1)
  codigoBarras        String?  @map("codigo_barras")
  numeroLote          String?  @map("numero_lote")
  nomeVacina          String?  @map("nome_vacina")
  status              String   @default("concluido") // concluido, pendente_aprovacao, aprovado, reprovado, cancelado
  observacoes         String?
  dataHora            DateTime @default(now()) @map("data_hora")
  // ═══ APPROVAL FIELDS ═══
  requerAprovacao     Boolean  @default(false) @map("requer_aprovacao")
  justificativa       String?
  motivoPadrao        String?  @map("motivo_padrao")
  aprovadoPor         Int?     @map("aprovado_por")
  aprovadoEm          DateTime? @map("aprovado_em")
  motivoReprovacao    String?  @map("motivo_reprovacao")
  impactaEstoque      Boolean  @default(true) @map("impacta_estoque")
  estoqueAplicadoEm   DateTime? @map("estoque_aplicado_em")
  atualizadoEm        DateTime @default(now()) @updatedAt @map("atualizado_em")
  // Relations
  unidade             Unidade? @relation(fields: [unidadeId], references: [id])
  lote                Lote?    @relation(fields: [loteId], references: [id])
  vacina              Vacina?  @relation(fields: [vacinaId], references: [id])
  cliente             Cliente? @relation(fields: [clienteId], references: [id])
  @@index([dataHora])
  @@index([clienteId])
  @@index([status])
  @@map("movimentacoes")
}

model MetaFinanceira {
  id                 Int      @id @default(autoincrement())
  setor              String   @default("vacinas")
  competencia        String
  valorMeta          Float    @map("valor_meta")
  valorRealizado     Float    @default(0) @map("valor_realizado")
  percentualAtingido Float    @default(0) @map("percentual_atingido")
  valorFaltante      Float    @default(0) @map("valor_faltante")
  observacao         String?
  criadoEm           DateTime @default(now()) @map("criado_em")
  @@map("metas_financeiras")
}

model RetiradaRecente {
  id           Int      @id @default(autoincrement())
  unidadeId    Int?     @map("unidade_id")
  vacinaNome   String?  @map("vacina_nome")
  lote         String?
  codigoBarras String?  @map("codigo_barras")
  clienteNome  String?  @map("cliente_nome")
  usuarioNome  String?  @map("usuario_nome")
  dataHora     DateTime @default(now()) @map("data_hora")
  @@map("retiradas_recentes")
}
